{
  "info": {
    "_postman_id": "smart-ward-ews-tests",
    "name": "Smart Ward EWS - Critical Vitals Testing",
    "description": "Test AWS S3 and Twilio alerts with critical patient vitals",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Test Patient",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"PAT001\",\n  \"name\": \"John Doe\",\n  \"age\": 45,\n  \"phone\": \"+919810325677\",\n  \"deviceId\": \"ESP32_001\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/patients",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "patients"
          ]
        }
      },
      "response": []
    },
